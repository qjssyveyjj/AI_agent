# ===== 大模型服务（OpenAI 兼容端点）=====
LLM_BASE_URL=https://ws-wuihthln7fewvx8r.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=qwen3-vl-plus
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ===== Agent 循环 =====
AGENT_MAX_STEPS=5

# ===== 内部 API（dev-api）=====
INTERNAL_API_BASE=http://192.168.126.200/dev-api
INTERNAL_API_TOKEN=
INTERNAL_API_TIMEOUT=15

# ===== 会话与存储 =====
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://aiagent:aiagent@postgres:5432/aiagent
SESSION_TTL_SECONDS=86400

# ===== 嵌入模型（知识库检索用，OpenAI 兼容 /v1/embeddings）=====
EMBED_BASE_URL=http://your-embed-host:8000/v1
EMBED_API_KEY=sk-your-key
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ===== 知识库 RAG =====
KB_TOP_K=5
KB_CHUNK_SIZE=800
KB_CHUNK_OVERLAP=100
KB_MIN_SCORE=0.0

# ===== 安全 =====
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
# 开发态可关闭鉴权（true/false）
AUTH_ENABLED=false

# ===== 图片预处理 =====
IMAGE_MAX_EDGE=1024
IMAGE_JPEG_QUALITY=85

# ===== CORS =====
CORS_ORIGINS=*
