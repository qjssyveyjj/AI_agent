# ===== 大模型服务（OpenAI 兼容端点）=====
LLM_BASE_URL=http://your-llm-host:8000/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=Qwen3-VL-Plus
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ===== Agent 循环 =====
AGENT_MAX_STEPS=5

# ===== 内部 API（dev-api）=====
INTERNAL_API_BASE=http://192.168.126.200/dev-api
INTERNAL_API_TOKEN=
INTERNAL_API_TIMEOUT=15

# ===== 会话与存储 =====
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://aiagent:aiagent@postgres:5432/aiagent
SESSION_TTL_SECONDS=86400

# ===== 安全 =====
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720
# 开发态可关闭鉴权（true/false）
AUTH_ENABLED=false

# ===== 图片预处理 =====
IMAGE_MAX_EDGE=1024
IMAGE_JPEG_QUALITY=85

# ===== CORS =====
CORS_ORIGINS=*
